<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next Pill"
        android:textColor="@color/primary_green"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/med_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_marginTop="4dp"
        android:text="Loading..."
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/med_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/med_name"
        android:layout_marginTop="2dp"
        android:text=""
        android:textColor="@color/status_upcoming"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/med_dose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/med_time"
        android:layout_marginTop="2dp"
        android:text=""
        android:textColor="@color/accent_teal"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/med_dose"
        android:layout_marginTop="12.dp"
        android:background="#33FFFFFF" />

    <TextView
        android:id="@+id/hydration_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider"
        android:layout_marginTop="12.dp"
        android:text="Hydration Progress"
        android:textColor="@color/secondary_teal"
        android:textSize="12sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/hydration_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_below="@id/hydration_label"
        android:layout_marginTop="8.dp"
        android:max="1000"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_bar" />

    <TextView
        android:id="@+id/hydration_progress_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/hydration_label"
        android:layout_alignParentEnd="true"
        android:text="0/2500 ml"
        android:textColor="@color/white"
        android:textSize="12sp" />

</RelativeLayout>
