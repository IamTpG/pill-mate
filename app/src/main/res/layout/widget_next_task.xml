<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next Pill"
        android:textColor="@color/primary_green"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/med_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_marginTop="4dp"
        android:text="Loading..."
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/med_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/med_name"
        android:layout_marginTop="2dp"
        android:text=""
        android:textColor="@color/status_upcoming"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/med_dose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/med_time"
        android:layout_marginTop="2dp"
        android:text=""
        android:textColor="@color/accent_teal"
        android:textSize="14sp"
        android:textStyle="bold" />

</RelativeLayout>
