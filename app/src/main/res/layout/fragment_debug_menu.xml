<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Debug Menu"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnGenerateData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generate Sample Data"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnClearData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear User Data"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="#FF0000"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnTriggerAlarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trigger Task Alarm (Test)"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnCreateTestSchedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Schedule (1 min future)"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnTriggerSpecific"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose &amp; Trigger Specific Alarm"
        android:layout_marginBottom="12dp"/>

</LinearLayout>
